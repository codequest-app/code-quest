# ── Logging ────────────────────────
# Pino log level: fatal | error | warn | info | debug | trace | silent
# LOG_LEVEL=info
# Human-readable output (requires pino-pretty). Default: false (JSON).
# LOG_PRETTY=false

# ── Remote Daemon ────────────────
# WebSocket URL of the server's /summoner endpoint
SUMMONER_SERVER=ws://127.0.0.1:3000/summoner

# Auth token (must match server's SUMMONER_TOKEN)
SUMMONER_TOKEN=your-token-here

# ── File Explorer ──────────────────
# Comma-separated list of allowed root directories. Defaults to home.
EXPLORER_ROOTS=/Users/me/projects,/Users/me/work
