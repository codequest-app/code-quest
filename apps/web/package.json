{
  "name": "@code-quest/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Code Quest client - React Terminal UI",
  "scripts": {
    "dev": "vite",
    "build": "pnpm clean && tsc && vite build",
    "build:release": "pnpm build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "biome check src",
    "clean": "rimraf --glob \"dist/*\" \"!dist/.env\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook --url http://127.0.0.1:6006",
    "test-storybook:ci": "concurrently -k -s first -n SB,TEST -c magenta,blue \"http-server storybook-static --port 6006 --silent\" \"wait-on -t 60000 tcp:6006 && test-storybook --url http://127.0.0.1:6006\""
  },
  "dependencies": {
    "@code-quest/shared": "workspace:*",
    "@headless-tree/core": "^1.6.3",
    "@headless-tree/react": "^1.6.3",
    "@heroicons/react": "^2.2.0",
    "@iconify-json/material-icon-theme": "^1.2.64",
    "@iconify/react": "^6.0.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@tanstack/react-virtual": "^3.13.24",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ansi-to-react": "^6.2.6",
    "clipboard": "^2.0.11",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "fuse.js": "^7.3.0",
    "mermaid": "^11.15.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-error-boundary": "^6.1.1",
    "react-hotkeys-hook": "^5.3.2",
    "react-intersection-observer": "^10.0.3",
    "react-json-view-lite": "^2.5.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "react-resizable-panels": "^4.11.1",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "use-debounce": "^10.1.1",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@code-quest/server": "workspace:*",
    "@code-quest/summoner": "workspace:*",
    "@rolldown/plugin-babel": "^0.2.3",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@storybook/test-runner": "^0.24.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.6",
    "babel-plugin-react-compiler": "1.0.0",
    "happy-dom": "^20.9.0",
    "javascript-obfuscator": "^5.4.2",
    "knip": "^6.13.1",
    "rimraf": "^6.1.3",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.3.0",
    "typescript": "6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-javascript-obfuscator": "^3.1.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6"
  }
}
