{
  "name": "@code-quest/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./test": "./src/test/index.ts"
  },
  "description": "Code Quest server - Terminal and Socket.io management",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/bin/server.ts",
    "build": "pnpm clean && tsdown",
    "build:release": "pnpm build && tsx obfuscate.ts",
    "start": "node --env-file=dist/.env dist/bin/server.js",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "biome check src",
    "db:generate": "pnpm --filter @code-quest/db-schema db:generate",
    "db:migrate:sqlite": "tsx --env-file=.env src/scripts/migrate-sqlite.ts",
    "db:migrate:mysql": "tsx --env-file=.env src/scripts/migrate-mysql.ts",
    "db:migrate": "pnpm db:migrate:sqlite && pnpm db:migrate:mysql",
    "db:sync:mysql-to-sqlite": "tsx --env-file=.env src/scripts/sync-mysql-to-sqlite.ts",
    "clean": "rimraf --glob \"dist/*\" \"!dist/.env\" \"!dist/node_modules\""
  },
  "dependencies": {
    "@code-quest/db-schema": "workspace:*",
    "@code-quest/schemas": "workspace:*",
    "@code-quest/transport": "workspace:*",
    "@code-quest/node-utils": "workspace:*",
    "@code-quest/summoner": "workspace:*",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "inversify": "^8.1.0",
    "mysql2": "^3.22.3",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.0",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.7.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.6",
    "javascript-obfuscator": "^5.4.2",
    "knip": "^6.13.1",
    "rimraf": "^6.1.3",
    "socket.io-client": "^4.8.3",
    "tsdown": "^0.22.0",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.6"
  }
}
