{
  "name": "code-quest",
  "version": "0.1.0",
  "private": true,
  "description": "RPG-style Claude Code experience",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"pnpm --filter server dev\" \"pnpm --filter client dev\"",
    "dev:mock": "concurrently -n server,client -c blue,green \"MOCK_CLI=true pnpm --filter server dev\" \"pnpm --filter client dev\"",
    "dev:remote": "concurrently -n server,client,daemon -c blue,green,yellow \"REMOTE_MODE=remote REMOTE_TOKEN=test-token-123 pnpm --filter server dev\" \"pnpm --filter client dev\" \"sleep 3 && pnpm dev:daemon\"",
    "dev:daemon": "pnpm --filter summoner dev -- --server ws://127.0.0.1:3000/summoner --token test-token-123",
    "dev:server": "pnpm --filter server dev",
    "dev:server:mock": "MOCK_CLI=true pnpm --filter server dev",
    "dev:client": "pnpm --filter client dev",
    "build": "pnpm --filter @code-quest/server build && pnpm --filter @code-quest/client build",
    "start": "pnpm --filter @code-quest/server start",
    "test": "pnpm --recursive test",
    "test:server": "pnpm --filter server test",
    "test:client": "pnpm --filter client test",
    "test:coverage": "pnpm --recursive test:coverage",
    "test:e2e": "playwright test",
    "test:e2e:mock": "MOCK_CLI=true playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "playwright:install": "playwright install chromium",
    "lint": "pnpm biome check .",
    "lint:fix": "pnpm biome check --write .",
    "clean": "pnpm --recursive clean",
    "prepare": "lefthook install"
  },
  "keywords": [
    "claude",
    "rpg",
    "terminal",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.2.1",
    "lefthook": "^2.1.6",
    "playwright": "^1.59.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
