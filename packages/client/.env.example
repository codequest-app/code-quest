# Server URL for WebSocket and HTTP connections
# Leave empty — dev uses Vite proxy, production uses same origin
VITE_SERVER_URL=

# Realtime transport used by createSocket().
#   ws       — raw WebSocket via WsClient + WsSocketAdapter (default)
#   socketio — socket.io-client (legacy / fallback)
# Server must mount the matching transport (TRANSPORT=ws|socketio|both).
# VITE_TRANSPORT=ws
