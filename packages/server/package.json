{
  "name": "@code-quest/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./test": "./src/test/index.ts"
  },
  "description": "Code Quest server - Terminal and Socket.io management",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/bin/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file=.env dist/bin/server.js",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "biome check src",
    "db:generate": "pnpm --filter @code-quest/db-schema db:generate",
    "db:migrate:sqlite": "tsx --env-file=.env src/scripts/migrate-sqlite.ts",
    "db:migrate:mysql": "tsx --env-file=.env src/scripts/migrate-mysql.ts",
    "db:migrate": "pnpm db:migrate:sqlite && pnpm db:migrate:mysql",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@code-quest/db-schema": "workspace:*",
    "@code-quest/shared": "workspace:*",
    "@code-quest/summoner": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "inversify": "^7.11.0",
    "mysql2": "^3.17.4",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.7.4",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "better-sqlite3": "^12.6.2",
    "socket.io-client": "^4.8.3",
    "supertest": "^6.3.4",
    "tsx": "^4.7.0",
    "typescript": "6.0.3",
    "vitest": "^3.2.4"
  }
}
