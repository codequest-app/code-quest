{
  "name": "@code-quest/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./test": "./src/test/index.ts"
  },
  "description": "Code Quest server - Terminal and Socket.io management",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/bin/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file=.env dist/bin/server.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "biome check src",
    "db:generate:sqlite": "drizzle-kit generate --config=drizzle-sqlite.config.ts",
    "db:generate:mysql": "drizzle-kit generate --config=drizzle-mysql.config.ts",
    "db:generate": "pnpm db:generate:sqlite && pnpm db:generate:mysql",
    "db:migrate:sqlite": "tsx --env-file=.env src/scripts/migrate-sqlite.ts",
    "db:migrate:mysql": "tsx --env-file=.env src/scripts/migrate-mysql.ts",
    "db:migrate": "pnpm db:migrate:sqlite && pnpm db:migrate:mysql",
    "db:studio:sqlite": "drizzle-kit studio --config=drizzle-sqlite.config.ts",
    "db:studio:mysql": "drizzle-kit studio --config=drizzle-mysql.config.ts",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@code-quest/shared": "workspace:*",
    "@code-quest/summoner": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "express": "^4.18.2",
    "fuse.js": "^7.1.0",
    "glob": "^13.0.6",
    "helmet": "^8.1.0",
    "inversify": "^7.11.0",
    "mysql2": "^3.17.4",
    "node-pty": "1.2.0-beta.10",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.7.4",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^1.2.1",
    "@vitest/ui": "^1.2.1",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.31.9",
    "memfs": "^4.57.1",
    "msw": "^2.1.2",
    "msw-fetch-mock": "^0.4.10",
    "socket.io-client": "^4.8.3",
    "supertest": "^6.3.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  }
}
