# Main database
# DATABASE_URL=mysql://user:password@localhost:3306/dbname

# Raw data recording (comma-separated: sqlite, mysql)
# RAW_STORE=sqlite,mysql
# RAW_STORE_SQLITE_PATH=./data/code-quest.db

# File Explorer — comma-separated list of allowed root directories
# Defaults to home directory if not set
# FILE_EXPLORER_ROOTS=/Users/user/projects,/Users/user/work
