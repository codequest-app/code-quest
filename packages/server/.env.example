# ── App ─────────────────────────────
# APP_PORT=3000

# ── Databases (each optional; presence = enabled; at least one required) ─
# MySQL (industry-standard DATABASE_URL)
DATABASE_URL=mysql://user:password@localhost:3306/dbname

# SQLite (Drizzle / Prisma style URL; bare path also accepted)
DATABASE_SQLITE_URL=file:./data/code-quest.db

# ── Raw event recording ─────────────
# Persist per-token streaming deltas to the raw_deltas table.
# Default false (deltas are ~80% of row volume; chat replay doesn't need them).
# Enable to allow RawEventPanel to inspect token-level streaming.
# RAW_EVENTS_PERSIST_DELTAS=false

# ── CLI (Claude Code child process) ─
# CLI_SYSTEM_PROMPT=
# CLI_AUTO_MODE=true
# CLI_BYPASS_PERMISSIONS=true

# ── File Explorer ──────────────────
# Comma-separated list of allowed root directories. Defaults to home.
# EXPLORER_ROOTS=/Users/user/projects,/Users/user/work
