# ── App ─────────────────────────────
# APP_PORT=3000

# ── Main database (shared session / settings / raw events) ─
# DATABASE_URL=mysql://user:password@localhost:3306/dbname

# ── Raw event recording (CLI stdin/stdout persistence) ─
# Comma-separated drivers. Valid: sqlite, mysql.
# RAW_EVENTS_DRIVERS=sqlite,mysql
# RAW_EVENTS_SQLITE_PATH=./data/code-quest.db
# Persist per-token streaming deltas to a separate raw_deltas table.
# Default false (deltas are ~80% of row volume; chat replay doesn't need them).
# RAW_EVENTS_PERSIST_DELTAS=false

# ── CLI (Claude Code child process) ─
# CLI_SYSTEM_PROMPT=
# CLI_AUTO_MODE=true
# CLI_BYPASS_PERMISSIONS=true

# ── File Explorer ──────────────────
# Comma-separated list of allowed root directories. Defaults to home.
# EXPLORER_ROOTS=/Users/user/projects,/Users/user/work
