# ── App ─────────────────────────────
# APP_PORT=3000

# ── Databases (each optional; presence = enabled; at least one required) ─
# MySQL (industry-standard DATABASE_URL)
DATABASE_URL=mysql://user:password@localhost:3306/dbname

# SQLite (Drizzle / Prisma style URL; bare path also accepted)
DATABASE_SQLITE_URL=file:./data/code-quest.db

# ── Raw event recording ─────────────
# Streaming deltas (content_block_delta) are ~80% of raw event volume. Chat
# replay doesn't need them; RawEventPanel debug does. Two independent knobs:
#
#   WRITE_DELTAS — persist deltas to raw_deltas table (write side).
#   READ_DELTAS  — UNION ALL raw_events + raw_deltas on getBySession (read side).
#
# Defaults (both false): clean mode.
# RAW_EVENTS_WRITE_DELTAS=false
# RAW_EVENTS_READ_DELTAS=false

# ── CLI (Claude Code child process) ─
# CLI_SYSTEM_PROMPT=
# CLI_AUTO_MODE=true
# CLI_BYPASS_PERMISSIONS=true
#
# Opus 4.7 requires an opt-in to include the cleartext thinking body;
# default 'summarized' makes the UI's Thinking panel actually show content.
# Set 'omitted' for privacy-sensitive deployments.
CLI_THINKING_DISPLAY=summarized

# ── File Explorer ──────────────────
# Comma-separated list of allowed root directories. Defaults to home.
# EXPLORER_ROOTS=/Users/user/projects,/Users/user/work
