# ── Remote Daemon ────────────────
# WebSocket URL of the server's /summoner endpoint
REMOTE_SERVER=ws://127.0.0.1:3000/summoner

# Auth token (must match server's REMOTE_TOKEN)
REMOTE_TOKEN=test-token-123

# ── File Explorer ──────────────────
# Comma-separated list of allowed root directories. Defaults to home.
EXPLORER_ROOTS=/Users/me/projects,/Users/me/work
